rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function memberDoc(householdId) {
      return /databases/$(database)/documents/households/$(householdId)/members/$(request.auth.uid);
    }

    function isMember(householdId) {
      return signedIn() && exists(memberDoc(householdId));
    }

    match /households/{householdId} {
      allow read: if isMember(householdId);
      allow write: if false;

      match /entries/{entryId} {
        allow read, write: if isMember(householdId);
      }

      match /templates/{templateId} {
        allow read, write: if isMember(householdId);
      }

      match /members/{uid} {
        allow read: if signedIn() && (request.auth.uid == uid || isMember(householdId));
        allow write: if false;
      }
    }
  }
}
